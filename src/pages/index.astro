</style>
<script is:inline>
  (function() {
    /* ── Mobile nav toggle ── */
    var t = document.getElementById('nav-toggle');
    var m = document.getElementById('nav-menu');
    t && t.addEventListener('click', function() { var o = m.classList.toggle('open'); t.setAttribute('aria-expanded', o); });
    m && m.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', function() { m.classList.remove('open'); t.setAttribute('aria-expanded', 'false'); }); });

    /* ── Contact form with validation ── */
    var f = document.getElementById("contact-form");
    if (f) {
      var rules = {
        name:    { min: 2,  msg: '请填写至少 2 个字符' },
        team:    { min: 2,  msg: '请填写团队名称，至少 2 个字符' },
        contact: { min: 3,  msg: '请填写微信、邮箱或手机号' },
        message: { min: 0,  msg: '' }
      };

      function clearErrors() {
        f.querySelectorAll('.form-row').forEach(function(r) { r.classList.remove('is-error'); });
      }

      function showError(id, msg) {
        var row = document.getElementById(id).closest('.form-row');
        var err = document.getElementById(id + '-err');
        row.classList.add('is-error');
        if (err) err.textContent = msg;
      }

      function validateField(el) {
        var id = el.id, v = el.value.trim(), r = rules[id];
        if (!r) return true;
        if (r.min > 0 && v.length < r.min) { showError(id, r.msg); return false; }
        document.getElementById(id).closest('.form-row').classList.remove('is-error');
        return true;
      }

      f.querySelectorAll('input, textarea').forEach(function(el) {
        el.addEventListener('blur', function() { if (el.value.trim()) validateField(el); });
        el.addEventListener('input', function() { if (el.closest('.form-row').classList.contains('is-error')) validateField(el); });
      });

      f.addEventListener('submit', function(e) {
        e.preventDefault();
        clearErrors();
        var valid = true;
        f.querySelectorAll('input[required], textarea[required]').forEach(function(el) { if (!validateField(el)) valid = false; });
        if (!valid) return;

        var btn = f.querySelector('button[type=submit]');
        var orig = btn.textContent;
        btn.textContent = '提交中...';
        btn.disabled = true;

        fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            access_key: '48aa5791-a3c2-4f16-87fc-f108bc085b5f',
            name: document.getElementById('name').value.trim(),
            team: document.getElementById('team').value.trim(),
            contact: document.getElementById('contact-info').value.trim(),
            message: document.getElementById('message').value.trim()
          })
        }).then(function(res) {
          if (res.ok) {
            var succ = document.getElementById('form-success');
            // Smooth hide form rows with animation
            f.querySelectorAll('.form-row').forEach(function(r) {
              r.style.transition = 'opacity 300ms ease, max-height 400ms ease, margin 300ms ease';
              r.style.opacity = '0';
              r.style.maxHeight = '0';
              r.style.margin = '0';
              r.style.overflow = 'hidden';
              r.style.padding = '0';
            });
            btn.style.transition = 'opacity 300ms ease';
            btn.style.opacity = '0';
            var trustEl = f.querySelector('.form-trust');
            if (trustEl) { trustEl.style.transition = 'opacity 300ms ease'; trustEl.style.opacity = '0'; }
            setTimeout(function() {
              f.querySelectorAll('.form-row').forEach(function(r) { r.style.display = 'none'; });
              btn.style.display = 'none';
              if (trustEl) trustEl.style.display = 'none';
              succ.hidden = false;
              succ.style.opacity = '0';
              succ.style.transition = 'opacity 350ms ease';
              requestAnimationFrame(function() { succ.style.opacity = '1'; });
            }, 400);
          } else {
            throw new Error('submit failed');
          }
        }).catch(function() {
          btn.textContent = orig;
          btn.disabled = false;
          var errEl = document.getElementById('form-error');
          errEl.hidden = false;
          errEl.style.opacity = '0';
          errEl.style.transition = 'opacity 350ms ease';
          requestAnimationFrame(function() { errEl.style.opacity = '1'; });
        });
      });
    }

    /* ── Scroll spy: highlight active nav link ── */
    var sections = document.querySelectorAll('section[id]');
    var navLinks = document.querySelectorAll('.nav-links a[href^="#"]');
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          navLinks.forEach(function(link) {
            link.classList.toggle('active', link.getAttribute('href') === '#' + entry.target.id);
          });
        }
      });
    }, { rootMargin: '-30% 0px -60% 0px' });
    sections.forEach(function(s) { observer.observe(s); });

    /* ── Back-to-top ── */
    var backBtn = document.getElementById('back-top');
    var scrollThreshold = 600;
    window.addEventListener('scroll', function() {
      var scrolled = window.scrollY > scrollThreshold;
      backBtn.hidden = !scrolled;
      backBtn.classList.toggle('visible', scrolled);
    }, { passive: true });
    backBtn.addEventListener('click', function() { window.scrollTo({ top: 0, behavior: 'smooth' }); });

    /* ── Interactive mock: click-to-cycle queries with typing animation ── */
    var mockSearch = document.getElementById('mock-search');
    var mockSearchText = document.getElementById('mock-search-text');
    var mockCursor = document.querySelector('.mock-search-cursor');
    var mockAns = document.getElementById('mock-ans');
    var mockSources = document.getElementById('mock-sources');
    var mockCycleHint = document.getElementById('mock-cycle-hint');

    var queries = [
      {
        q: '员工手册中关于年假的规定是什么？',
        a: '根据《员工手册》第三章第 2.4 条：员工入职满一年享有 <strong>5 个工作日</strong> 带薪年假……',
        sources: ['员工手册 v3.2 · 第三章', '考勤制度 v2.1 · 第五条']
      },
      {
        q: '报销流程需要哪些材料？',
        a: '根据《财务制度》第五章：报销需提供 <strong>发票原件、审批单、费用明细</strong>，金额超过 2000 元需部门负责人签字……',
        sources: ['财务制度 v2.0 · 第五章', '审批流程指南 v1.5 · 第三条']
      },
      {
        q: '产品规格参数在哪里可以查到？',
        a: '产品规格表在 <strong>《产品技术手册》附录 A</strong>，包含尺寸、材料、电气参数和认证信息……',
        sources: ['产品技术手册 v4.1 · 附录A', '质检标准 v3.0 · 第二节']
      }
    ];
    var queryIdx = 0;
    var isTyping = false;

    function typeText(el, html, callback, speed) {
      // Flatten into character+tag sequence, using only innerHTML to preserve tags
      var chars = [];
      var re = /(<[^>]+>)/g;
      var m, last = 0;
      while ((m = re.exec(html)) !== null) {
        for (var i = last; i < m.index; i++) chars.push(html[i]);
        chars.push(m[0]);
        last = re.lastIndex;
      }
      for (var i = last; i < html.length; i++) chars.push(html[i]);

      var idx = 0;
      var buf = '';
      el.innerHTML = '';
      var avgSpeed = speed || 35;
      function tick() {
        if (idx >= chars.length) {
          if (callback) callback();
          return;
        }
        buf += chars[idx];
        el.innerHTML = buf;
        idx++;
        var delay = avgSpeed + (Math.random() - 0.5) * 30;
        setTimeout(tick, delay);
      }
      tick();
    }

    function renderSources(sources, callback) {
      var html = '';
      sources.forEach(function(src, idx) {
        html += '<span class="source-tag is-new" style="animation-delay:' + (idx * 120) + 'ms">' + src + '</span>';
      });
      mockSources.innerHTML = html;
      mockSources.classList.remove('is-hidden');
      // Re-attach hover effect listeners after a frame
      if (callback) setTimeout(callback, sources.length * 120 + 480);
    }

    function cycleQuery() {
      if (isTyping) return;
      isTyping = true;

      queryIdx = (queryIdx + 1) % queries.length;
      var q = queries[queryIdx];

      // Fade out answer and sources
      mockAns.classList.add('is-fading');
      mockSources.classList.add('is-hidden');
      if (mockCursor) mockCursor.classList.remove('active');

      // Wait for fade, then update search text
      setTimeout(function() {
        mockSearchText.textContent = q.q;
        // Brief pause before typing answer
        setTimeout(function() {
          mockAns.classList.remove('is-fading');
          mockAns.textContent = '';
          if (mockCursor) mockCursor.classList.add('active');
          typeText(mockAns, q.a, function() {
            // Typing done
            if (mockCursor) mockCursor.classList.remove('active');
            setTimeout(function() {
              renderSources(q.sources, function() {
                isTyping = false;
                if (mockCycleHint) mockCycleHint.classList.add('visible');
              });
            }, 200);
          }, 38);
        }, 250);
      }, 180);
    }

    if (mockSearch && mockSearchText && mockAns && mockSources) {
      mockSearch.addEventListener('click', cycleQuery);
      mockSearch.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); cycleQuery(); }
      });

      // Show hint after a few seconds of idle
      setTimeout(function() {
        if (mockCycleHint) mockCycleHint.classList.add('visible');
      }, 4000);

      // Hide hint on first interaction, show again after cycle
      mockSearch.addEventListener('click', function() {
        if (mockCycleHint) mockCycleHint.classList.remove('visible');
      }, { once: false });
    }

    /* ── FAQ spring animation ── */
    var faqDetails = document.querySelectorAll('.faq-item');
    var faqPrefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    faqDetails.forEach(function(details) {
      var summary = details.querySelector('summary');
      var content = details.querySelector('p');
      if (!summary || !content) return;

      if (faqPrefersReduced) return; // let native toggle work, global CSS handles instant transition

      summary.addEventListener('click', function(e) {
        e.preventDefault();
        var closing = details.open;

        if (closing) {
          // Animate close
          var startH = content.scrollHeight;
          content.style.height = startH + 'px';
          content.style.overflow = 'hidden';
          content.style.opacity = '1';
          // Force reflow
          content.offsetHeight;

          var anim = content.animate([
            { height: startH + 'px', opacity: 1 },
            { height: 0, opacity: 0 }
          ], {
            duration: 180,
            easing: 'cubic-bezier(0.2, 0, 0, 1)',
            fill: 'forwards'
          });
          anim.onfinish = function() {
            details.open = false;
            content.style.height = '';
            content.style.overflow = '';
            content.style.opacity = '';
          };
        } else {
          // Animate open
          details.open = true;
          var endH = content.scrollHeight;
          content.style.height = '0';
          content.style.overflow = 'hidden';
          content.style.opacity = '0';
          // Force reflow
          content.offsetHeight;

          var anim = content.animate([
            { height: 0, opacity: 0 },
            { height: endH + 'px', opacity: 1 }
          ], {
            duration: 250,
            easing: 'cubic-bezier(0.2, 0, 0, 1)',
            fill: 'forwards'
          });
          anim.onfinish = function() {
            content.style.height = '';
            content.style.overflow = '';
            content.style.opacity = '';
          };
        }
      });
    });


    /* ── A: Precision entrance sequence ── */
    var heroVisual = document.getElementById('hero-visual');
    var heroHeadline = document.getElementById('hero-headline');
    var heroSub = document.getElementById('hero-sub');
    var heroActions = document.getElementById('hero-actions');
    var heroNote = document.getElementById('hero-note');

    function splitHeadlineWords() {
      if (!heroHeadline) return;
      var html = heroHeadline.innerHTML;
      var result = '';
      var re = /(<[^>]+>)|([^<\s]+)/g;
      var m;
      while ((m = re.exec(html)) !== null) {
        if (m[0][0] === '<') {
          result += m[0];
        } else {
          result += '<span class="hero-word">' + m[0] + '</span>';
        }
      }
      heroHeadline.innerHTML = result;
      return heroHeadline.querySelectorAll('.hero-word');
    }

    function runEntrance() {
      var words = splitHeadlineWords();

      // Set pre-entrance state
      if (heroVisual) heroVisual.classList.add('is-pre-entrance');
      if (heroSub) heroSub.classList.add('is-pre-entrance');
      if (heroActions) heroActions.classList.add('is-pre-entrance');
      if (heroNote) heroNote.classList.add('is-pre-entrance');

      // Frame 1: show mock with scale+blur transition
      requestAnimationFrame(function() {
        if (heroVisual) {
          heroVisual.classList.remove('is-pre-entrance');
          heroVisual.classList.add('is-entering');
        }

        // Stagger headline word reveal after mock appears
        setTimeout(function() {
          if (words && words.length) {
            words.forEach(function(word, i) {
              setTimeout(function() {
                word.classList.add('is-revealed');
              }, i * 25);
            });
          }
        }, 300);

        // Sub text after headline starts
        setTimeout(function() {
          if (heroSub) {
            heroSub.classList.remove('is-pre-entrance');
            heroSub.classList.add('is-entering');
          }
        }, 400);

        // CTA buttons stagger
        setTimeout(function() {
          if (heroActions) {
            heroActions.classList.remove('is-pre-entrance');
            heroActions.classList.add('is-entering');
          }
        }, 450);

        // Note text last
        setTimeout(function() {
          if (heroNote) {
            heroNote.classList.remove('is-pre-entrance');
            heroNote.classList.add('is-entering');
          }
        }, 500);
      });
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Skip entrance animation, show everything immediately
      if (heroVisual) heroVisual.style.opacity = '1';
      if (heroSub) heroSub.style.opacity = '1';
      if (heroActions) heroActions.style.opacity = '1';
      if (heroNote) heroNote.style.opacity = '1';
    } else {
      runEntrance();
    }

    /* ── C: Mock parallax during hero scroll ── */
    var mockParallax = document.querySelector('.mock-parallax');
    if (mockParallax && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      var heroSection = document.querySelector('.hero');
      var parallaxTicking = false;
      window.addEventListener('scroll', function() {
        if (parallaxTicking) return;
        parallaxTicking = true;
        requestAnimationFrame(function() {
          if (!heroSection) { parallaxTicking = false; return; }
          var rect = heroSection.getBoundingClientRect();
          var heroH = heroSection.offsetHeight;
          var progress = Math.max(0, Math.min(1, -rect.top / (heroH * 0.6)));
          var offset = progress * 16;
          mockParallax.style.transform = 'translateY(' + (-offset) + 'px)';
          parallaxTicking = false;
        });
      }, { passive: true });
    }

    /* ── Scroll reveal ── */
    var revealEls = document.querySelectorAll('.reveal-fade-up, .reveal-blur-in, .reveal-children');
    var elObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        if (el.classList.contains('reveal-fade-up') || el.classList.contains('reveal-blur-in')) {
          el.classList.add('is-revealed');
        }
        if (el.classList.contains('reveal-children')) {
          var children = el.querySelectorAll('.reveal-child');
          children.forEach(function(child, i) {
            child.style.transitionDelay = (i * 25) + 'ms';
            child.classList.add('is-revealed');
          });
        }
        elObserver.unobserve(el);
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(function(el) { elObserver.observe(el); });
  })();
</script>
