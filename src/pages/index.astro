    .nav-toggle { display: flex; flex-direction: column; gap: var(--space-1); background: none; border: none; cursor: pointer; padding: var(--space-3); border-radius: var(--radius-sm); min-width: 44px; min-height: 44px; align-items: center; justify-content: center; }
    .nav-toggle:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
    .nav-toggle span { display: block; width: 20px; height: 2px; background: var(--color-ink); border-radius: 1px; transition: transform 150ms var(--ease-smooth), opacity 150ms var(--ease-smooth); }
    .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
